# Google AI / Vertex AI
GOOGLE_API_KEY=your_google_ai_studio_api_key
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# Google OAuth (for Workspace APIs — Calendar, Gmail, Drive, Docs, Tasks)
# Create at: console.cloud.google.com -> APIs & Services -> Credentials -> OAuth 2.0 Client ID
# Application type: Desktop app
GOOGLE_CLIENT_ID=your_oauth_client_id
GOOGLE_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# AlloyDB AI (set USE_SQLITE=false to use AlloyDB instead of local SQLite)
USE_SQLITE=true
ALLOYDB_HOST=your_alloydb_private_ip
ALLOYDB_PORT=5432
ALLOYDB_DATABASE=sage
ALLOYDB_USER=postgres
ALLOYDB_PASSWORD=your_alloydb_password

# API
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=generate_with__python_-c__import_secrets;print(secrets.token_hex(32))
AI_REQUEST_TIMEOUT_SECONDS=45
GOOGLE_API_RETRY_ATTEMPTS=2
GOOGLE_API_RETRY_DELAY_SECONDS=1.0
DEMO_MODE=true
DEMO_USE_LIVE_ENRICHMENT=false

# Environment: local | staging | production
ENV=local
